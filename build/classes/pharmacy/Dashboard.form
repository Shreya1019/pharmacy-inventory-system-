                <Property name="columns" type="int" value="20"/>
                <Property name="font" type="java.awt.Font" editor="org.netbeans.beaninfo.editors.FontEditor">
                  <Font name="Kailasa" size="12" style="2"/>
                </Property>
                <Property name="foreground" type="java.awt.Color" editor="org.netbeans.beaninfo.editors.ColorEditor">
                  <Color blue="66" green="66" red="0" type="rgb"/>
                </Property>
                <Property name="lineWrap" type="boolean" value="true"/>
                <Property name="rows" type="int" value="5"/>
                <Property name="text" type="java.lang.String" value="Welcome to the Pharmacy Inventory System.&#xa;This system helps pharmacies manage their medicines efficiently.&#xa;It allows users to add new medicines, view the current inventory,&#xa;monitor low stock levels, and track medicines nearing expiry.&#xa;Features of this system include:&#xa;     &#x2022; Add and manage medicines&#xa;     &#x2022; View complete inventory records&#xa;     &#x2022; Low stock alerts&#xa;     &#x2022; Expiry date monitoring&#xa;     &#x2022; Simple and user-friendly interface&#xa;This application is developed using Java (Swing) and MySQL&#xa;to demonstrate database connectivity and inventory management&#xa;for pharmacy operations."/>
                <Property name="wrapStyleWord" type="boolean" value="true"/>
              </Properties>
            </Component>
          </SubComponents>
        </Container>
